NODE_ENV=production
PORT=8080
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1&schema=public
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<direct-host>:5432/postgres?schema=public
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace-only-if-backend-needs-supabase-api-access
CORS_ORIGIN=https://your-app.azurewebsites.net
UPLOAD_DIR_PATH=/home/site/uploads
UPLOAD_URL_PATH=uploads
FRONTEND_DIST_DIR=/home/site/wwwroot/backend/public
ENABLE_FILE_LOGGING=true
LOG_DIR=/home/site/logs
PRISMA_SCHEMA_SYNC_MODE=none
