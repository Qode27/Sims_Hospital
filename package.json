{
  "name": "sims-hospital",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npm run install:deps",
    "install:deps": "npm --prefix backend install && npm --prefix frontend install && npm --prefix desktop-electron install",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:desktop": "npm --prefix desktop-electron run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend test",
    "build:win": "npm --prefix desktop-electron run build:win"
  }
}
