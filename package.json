{
  "name": "sims-hospital",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npm run install:deps",
    "install:deps": "cd backend && npm install && cd .. && cd frontend && npm install && cd .. && cd desktop-electron && npm install && cd ..",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:desktop": "cd desktop-electron && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:win": "cd desktop-electron && npm run build:win"
  }
}
